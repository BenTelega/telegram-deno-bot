{
  "tasks": {
    "start": "deno run --allow-net --allow-env --allow-read --allow-write --allow-import main.ts",
    "dev": "deno run --watch --allow-net --allow-env --allow-read --allow-write --allow-import main.ts",
    "lint": "deno lint",
    "fmt": "deno fmt"
  },
  "imports": {
    "grammy": "https://deno.land/x/grammy@v1.23.1/mod.ts",
    "std/": "https://deno.land/std@0.224.0/"
  },
  "compilerOptions": {
    "strict": true
  },
  "lint": {
    "rules": {
      "tags": ["recommended"]
    }
  },
  "fmt": {
    "indentWidth": 2,
    "lineWidth": 100
  }
}


